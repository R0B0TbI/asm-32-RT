# ==========================================
# ДОКУМЕНТАЦИЯ И ЗАДАНИЯ (РАЗРЕШЕНО)
# ==========================================
!*.txt
!*.pdf
!*.docx
!*.doc

# ==========================================
# РЕЗУЛЬТАТЫ СБОРКИ (ИГНОРИРУЕМ)
# ==========================================
# Объектные файлы
*.o
*.obj

# Файлы листинга и отладки
*.lst
*.ls
*.map

# Исполняемые файлы (бинарники)
*.out
*.bin
*.exe
*.elf

[a-zA-Z0-9_.-]*

# ==========================================
# БЕЛЫЙ СПИСОК (РАЗРЕШЕННЫЕ ФАЙЛЫ)
# ==========================================
!*/
!*.asm
!*.sh
!*.json
!Dockerfile
!README.md
!LICENSE
!.gitignore
!build.sh

# ==========================================
# СИСТЕМНЫЙ МУСОР
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
~$*